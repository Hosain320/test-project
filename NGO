<script>
  // Donation amount selector
  function selectAmount(btn){
    document.querySelectorAll('.amount').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
  }

  // Testimonial carousel
  const quotes = [
    {
      text: "Before the well was built, I walked three hours each day for water. Now my children go to school instead. Hopewell gave us back our time and our hope.",
      name: "Amara Okafor",
      role: "Mother of three, Clean Water Initiative"
    },
    {
      text: "The farming program didn't just feed my family — it gave us a way to earn a living and plan for the future.",
      name: "Diego Ramirez",
      role: "Farmer, Nourish Communities"
    },
    {
      text: "My daughter is the first in our family to read. That's what Hopewell's classrooms gave us.",
      name: "Fatima Hassan",
      role: "Parent, Educate a Child"
    }
  ];
  let current = 0;
  function renderQuote(){
    document.getElementById('quoteText').textContent = quotes[current].text;
    document.getElementById('quoteName').textContent = quotes[current].name;
    document.getElementById('quoteRole').textContent = quotes[current].role;
    document.querySelectorAll('.dots button[data-i]').forEach(b=>{
      b.classList.toggle('active', Number(b.dataset.i) === current);
    });
  }
  function setQuote(i){ current = i; renderQuote(); }
  function shiftQuote(dir){
    current = (current + dir + quotes.length) % quotes.length;
    renderQuote();
  }
</script>

</body>
</html>
