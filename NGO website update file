<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reflections — Topics</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  :root{
    --ivory:#F6F1E4;
    --ink-deep:#08201D;
    --text-light:#FBF6E9;
    --text-gold:#EFD9A0;
    --gold-1:#B98A3E;
    --gold-2:#E3C27A;
  }

  *{ box-sizing:border-box; }

  body{
    margin:0;
    background: var(--ivory);
    font-family:'Inter', sans-serif;
    padding: 56px 5vw 80px;
  }

  .section-wrap{
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-head{
    text-align:center;
    margin-bottom: 44px;
  }

  .eyebrow{
    font-family:'Inter', sans-serif;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-size: 12px;
    font-weight: 700;
    color: var(--gold-1);
    display:inline-flex;
    align-items:center;
    gap:12px;
  }
  .eyebrow::before, .eyebrow::after{
    content:"";
    width: 30px;
    height:1px;
    background: var(--gold-2);
  }

  .section-title{
    font-family:'Playfair Display', serif;
    font-weight:700;
    font-size: clamp(28px, 4vw, 42px);
    color: #0B3D3A;
    margin: 16px 0 8px;
  }

  .section-sub{
    font-size:15px;
    color:#6B6455;
    max-width:520px;
    margin:0 auto;
    line-height:1.6;
  }

  .stack{
    display:flex;
    flex-direction:column;
    gap: 26px;
  }

  .card{
    position:relative;
    display:flex;
    align-items:center;
    gap: 28px;
    width:100%;
    min-height: 128px;
    border-radius: 999px;
    padding: 22px 44px;
    text-decoration:none;
    overflow:hidden;
    isolation:isolate;
    border: 1px solid rgba(255,255,255,0.08);
    transition: transform .5s cubic-bezier(.2,.7,.2,1), box-shadow .5s ease;
  }

  /* subtle woven texture, sits above the gradient */
  .card::before{
    content:"";
    position:absolute;
    inset:0;
    z-index:0;
    opacity:.10;
    background-image:
      radial-gradient(circle at 10px 10px, rgba(255,255,255,.9) 1.4px, transparent 1.6px);
    background-size: 26px 26px;
    mix-blend-mode: overlay;
  }

  /* sheen sweep on hover */
  .card::after{
    content:"";
    position:absolute;
    top:-50%;
    left:-30%;
    width: 60%;
    height:200%;
    background: linear-gradient(115deg, transparent 30%, rgba(255,255,255,0.22) 48%, transparent 65%);
    transform: translateX(-120%) rotate(8deg);
    transition: transform .9s ease;
    z-index:1;
    pointer-events:none;
  }

  .card:hover{
    transform: translateY(-5px) scale(1.012);
  }
  .card:hover::after{
    transform: translateX(220%) rotate(8deg);
  }

  .card:focus-visible{
    outline: 2px solid var(--gold-2);
    outline-offset: 4px;
  }

  .num{
    position:relative;
    z-index:2;
    flex: 0 0 auto;
    width: 54px;
    height: 54px;
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    font-family:'Playfair Display', serif;
    font-weight:700;
    font-size:20px;
    color: var(--ink-deep);
    background: linear-gradient(160deg, var(--text-gold) 0%, var(--gold-1) 100%);
    box-shadow: 0 0 0 4px rgba(255,255,255,0.14), 0 6px 16px rgba(0,0,0,0.25);
  }

  .card-title{
    position:relative;
    z-index:2;
    font-family:'Playfair Display', serif;
    font-weight:600;
    font-size: clamp(17px, 2vw, 23px);
    line-height:1.4;
    color: var(--text-light);
    margin:0;
    text-shadow: 0 2px 10px rgba(0,0,0,0.18);
    letter-spacing: 0.1px;
  }

  .arrow{
    position:relative;
    z-index:2;
    margin-left:auto;
    flex:0 0 auto;
    width: 42px;
    height:42px;
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    border: 1.5px solid rgba(255,255,255,0.4);
    color: var(--text-light);
    background: rgba(255,255,255,0.06);
    transition: background .4s ease, transform .4s ease, border-color .4s ease;
    flex-shrink:0;
  }

  .card:hover .arrow{
    background: rgba(255,255,255,0.95);
    border-color: rgba(255,255,255,0.95);
    color: var(--ink-deep);
    transform: translateX(4px);
  }

  .arrow svg{ width:17px; height:17px; }

  .empty-state{
    text-align:center;
    padding:60px 20px;
    color:#8a8371;
    font-family:'Inter', sans-serif;
    font-size:15px;
  }

  @media (max-width: 720px){
    body{ padding: 40px 5vw 60px; }
    .card{
      border-radius: 32px;
      padding: 22px 24px;
      gap:16px;
      min-height:auto;
    }
    .num{ width:42px; height:42px; font-size:16px; }
    .card-title{ font-size:16px; }
    .arrow{ width:36px; height:36px; }
  }

  @media (prefers-reduced-motion: reduce){
    .card, .card::after, .arrow{ transition:none; }
  }
</style>
</head>
<body>

<div class="section-wrap">

  <div class="section-head">
    <span class="eyebrow">Reflections</span>
    <h2 class="section-title">Faith, Reason &amp; Everyday Life</h2>
    <p class="section-sub">Six essays exploring where revelation, science, and modern questions of meaning meet.</p>
  </div>

  <div class="stack" id="cardStack"></div>

</div>


<script>
  /* ======================================================================
     YOUR ONLY JOB: add or remove titles below.
     - Just add a new string to the array (order = display order).
     - Save the file. A new card appears automatically:
       numbered correctly, colored automatically from the palette below,
       with no HTML editing required.
     ====================================================================== */
  const articles = [
    "Big Bang: Cosmic Laws in the Light of Faith",
    "Evolution and Human Uniqueness: A Theoretical and Logical Analysis",
    "Islam and Science: Conflict or Complementarity?",
    "Hijab: Not a Wall of Suspicion, but a Unique Shield of Protection",
    "Woman, Career, and the Crisis of Existence: A Dialogue",
    "Divine Decree Is Not a Chain… It Is a Door to Peace and Certainty"
  ];

  /* Optional: give any article a real link instead of "#".
     Match it by its exact position (0 = first article). Anything not
     listed here just defaults to "#". */
  const links = {
    // 0: "articles/big-bang.html",
  };

  /* ======================================================================
     COLOR PALETTE — 24 premium, hand-tuned gradients in the emerald /
     teal / gold family. Cards pull from this list in order and loop
     back to the start once they run out, so any number of articles
     is always covered and every card still looks intentional.
     Add more entries here any time to expand the rotation.
     ====================================================================== */
  const palette = [
    { gradient: "linear-gradient(120deg, #0B3D3A 0%, #1B7A72 70%, #B98A3E 130%)", shadow: "#0B3D3A" },
    { gradient: "linear-gradient(120deg, #0E4F55 0%, #0B3D3A 60%, #143028 100%)", shadow: "#0E4F55" },
    { gradient: "linear-gradient(120deg, #B98A3E 0%, #8C6A2E 55%, #0B3D3A 130%)", shadow: "#B98A3E" },
    { gradient: "linear-gradient(120deg, #123A44 0%, #1B7A72 55%, #0B3D3A 100%)", shadow: "#123A44" },
    { gradient: "linear-gradient(120deg, #08201D 0%, #125C52 60%, #B98A3E 140%)", shadow: "#08201D" },
    { gradient: "linear-gradient(120deg, #7A5A26 0%, #0E4F55 65%, #0B3D3A 120%)", shadow: "#7A5A26" },
    { gradient: "linear-gradient(125deg, #0F4C43 0%, #2D6E63 55%, #9C7B3D 130%)", shadow: "#0F4C43" },
    { gradient: "linear-gradient(125deg, #0A2B27 0%, #1A6B5E 60%, #9C7B3D 140%)", shadow: "#0A2B27" },
    { gradient: "linear-gradient(115deg, #125C52 0%, #08201D 60%, #8C6A2E 130%)", shadow: "#125C52" },
    { gradient: "linear-gradient(115deg, #1B7A72 0%, #0F4C43 55%, #7A5A26 130%)", shadow: "#1B7A72" },
    { gradient: "linear-gradient(130deg, #9C7B3D 0%, #0A2B27 60%, #0E4F55 130%)", shadow: "#9C7B3D" },
    { gradient: "linear-gradient(130deg, #2D6E63 0%, #0B3D3A 55%, #B98A3E 130%)", shadow: "#2D6E63" },
    { gradient: "linear-gradient(118deg, #08201D 0%, #123A44 55%, #9C7B3D 130%)", shadow: "#08201D" },
    { gradient: "linear-gradient(118deg, #8C6A2E 0%, #0F4C43 55%, #1B7A72 130%)", shadow: "#8C6A2E" },
    { gradient: "linear-gradient(122deg, #0B3D3A 0%, #9C7B3D 55%, #0A2B27 130%)", shadow: "#0B3D3A" },
    { gradient: "linear-gradient(122deg, #1A6B5E 0%, #7A5A26 55%, #125C52 130%)", shadow: "#1A6B5E" },
    { gradient: "linear-gradient(128deg, #B98A3E 0%, #08201D 55%, #0E4F55 130%)", shadow: "#B98A3E" },
    { gradient: "linear-gradient(128deg, #0E4F55 0%, #8C6A2E 55%, #2D6E63 130%)", shadow: "#0E4F55" },
    { gradient: "linear-gradient(112deg, #0A2B27 0%, #B98A3E 55%, #0F4C43 130%)", shadow: "#0A2B27" },
    { gradient: "linear-gradient(112deg, #125C52 0%, #1A6B5E 55%, #8C6A2E 130%)", shadow: "#125C52" },
    { gradient: "linear-gradient(135deg, #9C7B3D 0%, #0B3D3A 55%, #08201D 130%)", shadow: "#9C7B3D" },
    { gradient: "linear-gradient(135deg, #0F4C43 0%, #1B7A72 55%, #7A5A26 130%)", shadow: "#0F4C43" },
    { gradient: "linear-gradient(105deg, #2D6E63 0%, #0A2B27 55%, #B98A3E 130%)", shadow: "#2D6E63" },
    { gradient: "linear-gradient(105deg, #123A44 0%, #8C6A2E 55%, #125C52 130%)", shadow: "#123A44" }
  ];

  function hexToRgba(hex, alpha){
    const h = hex.replace('#','');
    const r = parseInt(h.substring(0,2),16);
    const g = parseInt(h.substring(2,4),16);
    const b = parseInt(h.substring(4,6),16);
    return `rgba(${r}, ${g}, ${b}, ${alpha})`;
  }

  const arrowIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>`;

  function renderCards(){
    const stack = document.getElementById('cardStack');

    if (!articles.length){
      stack.innerHTML = `<div class="empty-state">No articles yet — add titles to the <code>articles</code> array.</div>`;
      return;
    }

    const html = articles.map((title, i) => {
      const colorSet = palette[i % palette.length];
      const href = links.hasOwnProperty(i) ? links[i] : "#";
      const shadowSoft = hexToRgba(colorSet.shadow, 0.18);
      const shadowStrong = hexToRgba(colorSet.shadow, 0.28);

      return `
        <a href="${href}" class="card"
           style="background:${colorSet.gradient};
                  box-shadow: 0 10px 20px ${shadowSoft}, 0 24px 48px ${shadowSoft};"
           onmouseover="this.style.boxShadow='0 14px 26px ${shadowStrong}, 0 32px 64px ${shadowStrong}'"
           onmouseout="this.style.boxShadow='0 10px 20px ${shadowSoft}, 0 24px 48px ${shadowSoft}'">
          <span class="num">${i + 1}</span>
          <p class="card-title">${title}</p>
          <span class="arrow">${arrowIcon}</span>
        </a>`;
    }).join('');

    stack.innerHTML = html;
  }

  renderCards();
</script>

</body>
</html>
